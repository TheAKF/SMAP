{
  "expo": {
    "name": "School Map",
    "slug": "school-map",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "school-map",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.smap",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "כדי לבחור תמונת פרופיל",
        "NSCameraUsageDescription": "כדי לצלם תמונת פרופיל",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.smap"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoadsInWebContent": true
        },
        "FirebaseAppDelegateProxyEnabled": false
      }
    },
    "android": {
      "package": "com.smap",
      "adaptiveIcon": {
        "backgroundColor": "#07111f",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "כדי לבחור תמונת פרופיל"
        }
      ],
      "./plugins/withFirebaseIos",
      "./plugins/withModularHeaders"
    ],
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "35816f52-2674-43b5-993b-e88b137a3e99"
      }
    }
  }
}
